{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "types": ["mocha"],
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "lib": ["esnext", "DOM"],
    "useDefineForClassFields": false
  },
  "include": ["src/**/*", "test/**/*"]
}
